# =============================================================================
# WhatsApp AI Bot - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Required variables must be set for the application to start.
# =============================================================================

# -----------------------------------------------------------------------------
# Required Variables
# -----------------------------------------------------------------------------

# OpenAI API key for GPT-4 integration
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Z-API instance ID for WhatsApp integration
# Obtain from: https://developer.z-api.io/
ZAPI_INSTANCE_ID=your-zapi-instance-id

# Z-API authentication token
# Obtain from: https://developer.z-api.io/
ZAPI_TOKEN=your-zapi-token-here

# Z-API webhook signature secret for payload validation
# Used to verify incoming webhook requests are from Z-API
ZAPI_WEBHOOK_SECRET=your-webhook-secret-here

# Keyword that triggers human handoff (case-insensitive substring match)
# Supports multiple triggers separated by | (pipe)
# Each keyword must be between 2 and 50 characters
HANDOFF_TRIGGER=falar com atendente|quero cancelar|reclamação

# -----------------------------------------------------------------------------
# Optional Variables
# -----------------------------------------------------------------------------

# HTTP port for the Express server (default: 3000)
PORT=3000

# AI system prompt that defines the assistant's behavior and personality
# Falls back to config file if not set. Maximum 4000 characters.
SYSTEM_PROMPT=You are a helpful WhatsApp assistant.

# Message retention period in hours (default: 24, min: 1, max: 168)
# Messages older than this will be cleaned up periodically
RETENTION_HOURS=24
